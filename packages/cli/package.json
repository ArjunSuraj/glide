{
  "name": "glide-editor",
  "version": "0.1.1",
  "description": "Visual editor for web dev servers — select, edit text, move elements, reorder, duplicate, and apply changes directly to source. Works with React, Vue, and Angular.",
  "keywords": [
    "visual-editor",
    "devtools",
    "react",
    "vue",
    "angular",
    "overlay",
    "component",
    "live-edit",
    "dev-server",
    "proxy",
    "cli",
    "tailwind"
  ],
  "author": "Arjun Suraj",
  "homepage": "https://github.com/ArjunSuraj/glide",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ArjunSuraj/glide.git",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "bin": {
    "glide": "bin/glide.js",
    "glide-editor": "bin/glide.js"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-assets.js",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "prepublishOnly": "pnpm run build && pnpm run test:run"
  },
  "dependencies": {
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "http-proxy": "^1.18.1",
    "jscodeshift": "^17.1.0",
    "open": "^10.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@glide-editor/shared": "workspace:*",
    "@types/http-proxy": "^1.17.15",
    "@types/jscodeshift": "^17.3.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}